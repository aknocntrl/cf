#include<bits/stdc++.h>
using namespace std;
int main(){
    int t;
    cin>>t;
    while(t--){
        string s;
        cin>>s;
        bool ans=true;
        if(s.length()%2==0){
            for(int i=0;i<s.length()/2;i++){
                if(s[i]!=s[i+s.length()/2]){
                    ans=false;}}}
        else{
            ans=false;}
        cout<<(ans?"YES":"NO")<<endl;}
    return 0;
}